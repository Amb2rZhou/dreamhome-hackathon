# 复制成 .env 并填值。全部留空 = mock 模式，无需外网也能跑通链路。

# 3D 生成 provider: mock | tripo | meshy
GEN3D_PROVIDER=mock

# Tripo（demo 首选）
TRIPO_API_KEY=
# TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi

# Meshy（备选）
MESHY_API_KEY=
# MESHY_BASE_URL=https://api.meshy.ai/openapi/v1

# 语音编辑意图解析（缺则用关键词规则兜底）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# 部署到公网后改成公网域名，用于拼结果 URL
PUBLIC_BASE_URL=http://localhost:8000
