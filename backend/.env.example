# 复制成 .env 并填值。全部留空 = mock 模式，无需外网也能跑通链路。

# 3D 生成 provider: mock | selfhost(自部署TRELLIS,填REMOTE_GPU_URL) | fal | tripo | meshy
GEN3D_PROVIDER=mock

# fal.ai TRELLIS（demo 首选：图生 3D 带贴图 GLB）
FAL_KEY=
FAL_TRELLIS_ENDPOINT=fal-ai/trellis

# Tripo（备选）
TRIPO_API_KEY=
# TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi

# Meshy（备选）
MESHY_API_KEY=
# MESHY_BASE_URL=https://api.meshy.ai/openapi/v1

# 语音编辑意图解析（缺则用关键词规则兜底）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- 资产库(docs/asset-library-plan.md) ----
# SQLite 路径(默认 storage/dreamhome.db)
# DB_PATH=
# 实时单帧检测: mock | remote(GPU 机上的 gpu/server.py)
DETECT_PROVIDER=mock
REMOTE_GPU_URL=
# 打标签: mock | anthropic | dashscope(qwen-vl,国内直连首选)
LABELS_PROVIDER=mock
DASHSCOPE_API_KEY=
DASHSCOPE_VL_MODEL=qwen-vl-max

# 部署到公网后改成公网域名，用于拼结果 URL
PUBLIC_BASE_URL=http://localhost:8000

# ---- 当前真跑配置(2026-07-21,量产在用;真实值向 Boss 索取,绝不提交 .env)----
# GPU 服务器 = 阿里云按量付费 A10,公网 IP 每次开机都变:
#   开机后填新 IP,探活 curl http://<IP>:9000/health
# DETECT_PROVIDER=remote
# GEN3D_PROVIDER=selfhost
# REMOTE_GPU_URL=http://<GPU公网IP>:9000
# LABELS_PROVIDER=dashscope
# DASHSCOPE_API_KEY=<向Boss索取>
# 抠图补全(强制SOP环节): module = 走 serina 的 segment_api(本机 :8002)
# ENHANCE_PROVIDER=module
# ENHANCE_MODEL=wan2.7-image        # ¥0.2/张;wan2.7-image-pro ¥0.5
# SEGMENT_API_URL=http://localhost:8002
# PIPELINE_MAX_ASSETS=3             # 试产限流
# CATEGORY_RECHECK=1                # 分段品类复核开关
