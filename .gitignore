# ---- 依赖 / 虚拟环境（体积大，绝不入库）----
node_modules/
venv/
.venv/
__pycache__/
*.pyc

# ---- 构建产物 / 缓存 ----
dist/
build/
.expo/
.expo-shared/
*.tsbuildinfo
.cache/

# ---- 大二进制素材（视频 / 3D 模型 / 图片源文件）----
*.mp4
*.mov
*.avi
*.glb
*.gltf
*.obj
*.fbx
*.usdz
*.psd
*.zip

# ---- 环境变量 / 密钥 ----
.env
.env.*
!.env.example

# ---- 系统 / 编辑器 ----
.DS_Store
*.log

# ---- web 前端物料（可由脚本重生成，不入库）----
# 第三方库与 PWA 图标体积大/为二进制，用 `node web/tools/setup-assets.mjs` 一键生成
web/vendor/
web/icons/
